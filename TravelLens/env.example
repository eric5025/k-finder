# Perplexity AI API (이미지 분석 및 번역)
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Google Maps API (react-native-maps / TouristMap — Android·iOS 네이티브 빌드 시 app.config에 주입)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Kakao Map API (카카오 지도)
KAKAO_MAP_API_KEY=your_kakao_map_api_key_here

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
FIREBASE_APP_ID=your_firebase_app_id_here
FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id_here

# 국토교통부 ITS CCTV API (https://openapi.its.go.kr)
# 공공데이터포털(data.go.kr) → "국가교통정보센터_실시간 CCTV 영상 정보 조회" 서비스 신청
ITS_CCTV_API_KEY=your_its_cctv_api_key_here

# App Configuration
APP_ENV=development
DEBUG=true 